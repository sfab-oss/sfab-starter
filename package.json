{
  "name": "sfab-starter",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "check:cycles": "madge --circular --extensions ts,tsx --exclude '(\\.gen\\.|/org/)' packages",
    "check:dead-code": "knip",
    "test": "turbo test",
    "test:e2e": "pnpm --filter web test:e2e",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @workspace/db db:generate",
    "db:studio": "pnpm --filter @workspace/db db:studio",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:migrate:prod": "pnpm --filter web db:migrate:prod",
    "db:seed": "pnpm --filter web db:seed",
    "db:seed:prod": "pnpm --filter web db:seed:prod",
    "db:reset": "pnpm --filter web db:reset",
    "db:list": "pnpm --filter web db:list",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@workspace/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "knip": "5",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "turbo": "^2.7.4",
    "typescript": "5.9.3",
    "ultracite": "7.0.11"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
