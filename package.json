{
  "name": "sfab-starter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm --filter web-tanstack test",
    "test:e2e": "pnpm --filter web-tanstack test:e2e",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @workspace/db-d1 db:generate",
    "db:studio": "pnpm --filter @workspace/db-d1 db:studio",
    "db:migrate": "pnpm --filter web-tanstack db:migrate",
    "db:migrate:prod": "pnpm --filter web-tanstack db:migrate:prod",
    "db:seed": "pnpm --filter web-tanstack db:seed",
    "db:seed:prod": "pnpm --filter web-tanstack db:seed:prod",
    "db:reset": "pnpm --filter web-tanstack db:reset",
    "db:list": "pnpm --filter web-tanstack db:list",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.7.4",
    "typescript": "5.9.3",
    "ultracite": "7.0.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
