  "scripts": {
    "build:registry": "tsx src/scripts/build-registry.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/ui": "workspace:*",
    "lucide-react": "^0.475.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-resizable-panels": "^3.0.6",
    "shiki": "^3.21.0",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@turbo/gen": "^2.5.5",
    "@types/node": "^20.19.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@workspace/typescript-config": "workspace:*",
    "next": "16.1.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  }
