{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 4011",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run --project node --project workers",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types && wrangler types ../../packages/env/src/env.d.ts --include-runtime=false && node ../../packages/env/scripts/postprocess-env.mjs",
    "generate-routes": "tsr generate",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm --filter @workspace/db db:generate",
    "db:migrate": "wrangler d1 migrations apply sfab-starter-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply sfab-starter-db --remote",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && pnpm db:migrate",
    "db:list": "wrangler d1 migrations list sfab-starter-db --local",
    "db:studio": "pnpm --filter @workspace/db db:studio"
  },
  "dependencies": {
    "@ai-sdk/google": "3.0.10",
    "@ai-sdk/openai": "^3.0.82",
    "@ai-sdk/react": "^3.0.223",
    "@cloudflare/codemode": "0.4.2",
    "@cloudflare/shell": "0.4.1",
    "@cloudflare/think": "0.12.1",
    "@cloudflare/vite-plugin": "1.43.0",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.7.11",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-cli": "^1.167.18",
    "@tanstack/router-plugin": "^1.168.19",
    "@workspace/agent": "workspace:*",
    "@workspace/auth": "workspace:*",
    "@workspace/contract": "workspace:*",
    "@workspace/core": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/ui": "workspace:*",
    "agents": "0.17.3",
    "ai": "^6.0.221",
    "date-fns": "^4.4.0",
    "github-slugger": "^2.0.0",
    "hono": "^4.12.28",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwindcss": "^4.3.2",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@playwright/test": "^1.61.1",
    "@tanstack/devtools-vite": "^0.3.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/runner": "^4.1.10",
    "@vitest/snapshot": "^4.1.10",
    "@workspace/tsconfig": "workspace:*",
    "better-auth": "1.6.19",
    "jsdom": "^27.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.10",
    "wrangler": "4.107.0"
  }
}
