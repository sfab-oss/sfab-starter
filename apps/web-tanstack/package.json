{
  "name": "web-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm --filter @workspace/db-d1 db:generate",
    "db:migrate": "wrangler d1 migrations apply web-tanstack-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply web-tanstack-db --remote",
    "db:seed": "wrangler d1 execute web-tanstack-db --file=../../packages/db-d1/seed.sql --local",
    "db:seed:prod": "wrangler d1 execute web-tanstack-db --file=../../packages/db-d1/seed.sql --remote",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && pnpm db:migrate && pnpm db:seed",
    "db:list": "wrangler d1 migrations list web-tanstack-db --local",
    "db:studio": "pnpm --filter @workspace/db-d1 db:studio"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@workspace/auth": "workspace:*",
    "@workspace/db-d1": "workspace:*",
    "@workspace/ui": "workspace:*",
    "hono": "^4.11.9",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "tailwindcss": "^4.1.18",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@workspace/typescript-config": "workspace:*",
    "jsdom": "^27.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.68.1"
  }
}
