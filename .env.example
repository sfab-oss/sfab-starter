# Database Configuration
# Required: PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@localhost:5432/dbname

# Authentication Configuration
# Required: Secret key for Better Auth (minimum 32 characters)
BETTER_AUTH_SECRET=

# Application Features
# Optional: Enable design system routes (default: false)
NEXT_PUBLIC_DESIGN_SYSTEM_ENABLED=false

# Vercel Environment (auto-populated by Vercel)
# NEXT_PUBLIC_VERCEL_ENV=production|preview|development
# NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=your-app.vercel.app
# NEXT_PUBLIC_VERCEL_BRANCH_URL=your-branch-url.vercel.app

AI_GATEWAY_API_KEY=xxxxxxxxxxxxxxxxx
OPENAI_API_KEY=xxxxxxxxxxxxxxxxx

